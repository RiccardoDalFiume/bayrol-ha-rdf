# .env.example
# Copia questo file in .env e compila i tuoi dati reali.
# Il file .env è ignorato da git (.gitignore) per non esporre le credenziali.

# Inserisci il codice a 8 cifre per l'accoppiamento app (App Link Code)
BAYROL_APP_LINK_CODE=12345678

# Specifica il tipo di dispositivo ("Automatic SALT", "Automatic Cl-pH", "PM5 Chlorine")
BAYROL_DEVICE_TYPE="Automatic SALT"

# Opzionale: Se hai già il token e il seriale
# BAYROL_ACCESS_TOKEN=tuo_token_qui
# BAYROL_DEVICE_ID=tuo_seriale_qui
