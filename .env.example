# .env.example
# Copy this file to .env and fill in real values.
# The .env file is ignored by git to avoid exposing credentials.

# Enter the 8-character App Link Code from Bayrol web app
BAYROL_APP_LINK_CODE=12345678

# Set the device type ("Automatic SALT", "Automatic Cl-pH", "PM5 Chlorine")
BAYROL_DEVICE_TYPE="Automatic SALT"

# Enable live integration tests (optional, disabled by default)
BAYROL_RUN_LIVE_TESTS=false

# Optional: if already available, set token and device serial directly
# BAYROL_ACCESS_TOKEN=your_token_here
# BAYROL_DEVICE_ID=your_device_serial_here
